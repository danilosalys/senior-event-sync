# ============================================
# Senior Event Sync - Variáveis de ambiente
# Copie para .env e preencha os valores.
# ============================================

# Banco de dados AD_Sync (compartilhado com imediato-ad-sync)
DB_SERVER=localhost
DB_USER=sa
DB_PASSWORD=
DB_DATABASE=AD_Sync
DB_PORT=1433
# DB_TRUST_SERVER_CERTIFICATE=false

# Banco de dados Sênior
SENIOR_DB_SERVER=localhost
SENIOR_DB_USER=senior_user
SENIOR_DB_PASSWORD=
SENIOR_DB_DATABASE=SeniorDB
SENIOR_DB_PORT=1433
# SENIOR_DB_TRUST_SERVER_CERTIFICATE=false

# Cron Jobs (expressão cron)
CRON_SENIOR_TO_AD=*/5 * * * *
CRON_AD_TO_SENIOR=*/2 * * * *

# Quais eventos processar: true = usar tabela AD_EVENT_TYPES (STATUS=ACTIVE) no banco ImediatoADSync (padrão).
# false = usar ENABLED_EVENT_TYPES abaixo (lista no .env).
# USE_EVENT_TYPES_FROM_DATABASE=true
# ENABLED_EVENT_TYPES=USER_UPDATE_DISPLAY_NAME,USER_DISABLE_TERMINATION,USER_UPDATE_TITLE,USER_DISABLE_LEAVE

# API REST
API_PORT=3001
# true = habilitada (padrão), false = desabilitada
API_ENABLED=true

# Opcional: nível de log (debug | info | warn | error). Padrão: info
# LOG_LEVEL=info

# Opcional: origens CORS permitidas, separadas por vírgula
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Opcional: chave para criptografia em config/secure/service-config.json
# ENCRYPTION_KEY=
